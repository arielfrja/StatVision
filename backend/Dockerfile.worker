FROM node:20-slim

WORKDIR /app

# Install dependencies needed for build AND ffmpeg for video processing
RUN apt-get update && apt-get install -y openssl curl ffmpeg && rm -rf /var/lib/apt/lists/*

COPY package*.json ./

RUN npm ci

COPY . .

RUN npm run build

# Prune dev dependencies to keep image small
RUN npm prune --production

EXPOSE 8080

# Explicitly start the Worker
CMD ["node", "build/startWorker.js"]
